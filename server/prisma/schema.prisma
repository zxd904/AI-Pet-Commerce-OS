generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  passwordHash       String
  plan               String              @default("free")
  expireTime         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  userProducts       UserProduct[]
  analyticsRecords   AnalyticsRecord[]
  orders             Order[]
}

model Order {
  id                Int      @id @default(autoincrement())
  orderNo           String   @unique
  userId            Int
  amount            Float
  plan              String
  status            String   @default("pending")
  paymentMethod     String?
  createdAt         DateTime @default(now())
  paidAt            DateTime?

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProduct {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  status    String   @default("saved")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Product {
  id             Int      @id @default(autoincrement())
  productName    String   @unique
  painPoint      String
  sellingPoints  String
  viralScore     Int
  targetUsers    String
  recommendation String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  content        Content?
  userProducts   UserProduct[]
}

model Content {
  id              Int      @id @default(autoincrement())
  productId       Int      @unique
  douyinScript    String
  xiaohongshuPost String
  liveScript      String
  adTitles        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductItem {
  id                Int       @id @default(autoincrement())
  title             String
  description       String?
  price             Float
  cost              Float?
  profitMargin      Float?
  score             Int       @default(0)
  level             String    @default("C")
  decision          String    @default("WATCH")
  reason            String?
  recommendedPrice  Float?
  expectedProfit    Float?
  status            String    @default("draft")
  shopifyId         String?
  douyinProductId   String?
  douyinStatus      String?
  taobaoId          String?
  pddId             String?
  imageUrl          String?
  category          String?
  supplierPrice     Float?
  shippingCost      Float?
  salesVolume       Int?
  rating            Float?
  reviewCount       Int?
  source            String?
  sourceUrl         String?
  tags              String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  logs              Log[]
}

model Log {
  id          Int      @id @default(autoincrement())
  productId   Int?
  action      String
  result      String
  message     String?
  details     String?
  createdAt   DateTime @default(now())

  product     ProductItem? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Supplier {
  id            Int      @id @default(autoincrement())
  name          String
  platform      String
  productId     Int?
  supplierPrice Float
  moq           Int?
  leadTime      Int?
  quality       String?
  reliability   Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SelectionTask {
  id          Int      @id @default(autoincrement())
  status      String   @default("pending")
  totalItems  Int      @default(0)
  processed   Int      @default(0)
  listed      Int      @default(0)
  rejected    Int      @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model AnalyticsRecord {
  id         Int      @id @default(autoincrement())
  userId     Int
  metricType String
  value      Float
  recordDate DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}