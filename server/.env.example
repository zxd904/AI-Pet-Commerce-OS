# ===========================================
# AI Pet Commerce OS - 后端环境变量配置
# ===========================================

# 服务端口（Railway 自动设置）
PORT=3001

# 运行环境
NODE_ENV=production

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# CORS 允许的前端域名（多个用逗号分隔）
CORS_ORIGIN=https://your-frontend-domain.vercel.app,https://your-frontend-domain.netlify.app

# 数据库连接 URL（Railway PostgreSQL）
DATABASE_URL=postgresql://user:password@host:5432/database

# 支付配置
PAY_KEY=your-payment-sign-key
BASE_URL=https://your-railway-backend.up.railway.app

# AI 模型配置（Ollama）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# 抖音小店 API（可选）
DOUYIN_APP_ID=
DOUYIN_APP_SECRET=
DOUYIN_SHOP_ID=

# 定时任务配置
CRON_SCHEDULE=0 */6 * * *
